# ═══════════════════════════════════════════
# DevPilot 配置
# ═══════════════════════════════════════════

# --- Auth Service ---
AUTH_HOST=127.0.0.1
AUTH_PORT=16001
AUTH_DATABASE_URL=sqlite+aiosqlite:///./data/auth.db
AUTH_CORS_ORIGINS=*
AUTH_DEBUG=false

# --- JWT (RS256) ---
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_FILE=/opt/devpilot/keys/jwt_private.pem
JWT_PUBLIC_KEY_FILE=/opt/devpilot/keys/jwt_public.pem
JWT_EXPIRE_MINUTES=1440

# --- Admin bootstrap ---
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=

# --- ClawAPI Proxy (API Key never exposed to frontend) ---
CLAWAPI_URL=http://127.0.0.1:16002
CLAWAPI_KEY=sk-your-clawapi-key-here
